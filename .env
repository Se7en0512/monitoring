# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/library-visitor-db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Firebase (optional)
FIREBASE_PROJECT_ID=library-monitoringsystem
FIREBASE_PRIVATE_KEY=your_firebase_private_key_here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@library-monitoringsystem.iam.gserviceaccount.com

# Email Configuration (for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100